# OpenAI API 平台密钥。Codex Agent 模式可留空；不要填写 ChatGPT 登录密码或浏览器 Cookie。
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# 企业微信群机器人 Webhook，仅在服务端使用。
WECOM_BOT_WEBHOOK=

# GitHub Pages 项目地址，不带结尾斜杠。
VISUAL_RADAR_PUBLIC_URL=https://visual-radar-owner.github.io/visual-radar

# 保护自动采集、AI 解读、生成和推送接口的随机长字符串。
CRON_SECRET=

# 云端部署时请指向持久化磁盘目录。
VISUAL_RADAR_DATA_DIR=./data

PORT=3099
