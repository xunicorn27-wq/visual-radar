{
  "name": "visual-radar",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:client": "vite --host --port 3100",
    "dev:server": "tsx server/index.ts",
    "daily": "tsx scripts/run-daily.ts",
    "agent:import": "tsx scripts/import-agent-output.ts",
    "build": "vite build && esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "start": "NODE_ENV=production node dist/index.js",
    "test": "vitest run",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.21.2",
    "lucide-react": "^0.453.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "wouter": "^3.3.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^24.7.0",
    "@types/react": "^19.2.1",
    "@types/react-dom": "^19.2.1",
    "@vitejs/plugin-react": "^5.0.4",
    "esbuild": "^0.25.0",
    "tsx": "^4.20.6",
    "typescript": "^5.6.3",
    "vite": "^7.1.9",
    "vitest": "^2.1.9"
  },
  "packageManager": "pnpm@11.9.0"
}
